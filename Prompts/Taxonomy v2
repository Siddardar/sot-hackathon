"""
taxonomy.py — Personal Data Leak: leakage taxonomy (v2).

Rewritten to match what real ChatGPT and Claude exports actually contain.

Changes from v1:
  - Tier S added for stated-profile data (custom instructions, saved memory).
    This is NOT conversational leakage and must be scored separately, or the
    numbers are meaningless.
  - Tier M added for metadata leakage (timestamps, message cadence, language),
    which exports carry and which no prompt-only tool usually looks at.
  - Every category now records `source_scope`: which parts of the normalized
    transcript the profiler is allowed to draw evidence from.
  - `subject` field on every finding, so third-party mentions can be tagged and
    dropped rather than silently profiled.
"""

from dataclasses import dataclass
from typing import Literal

Tier = Literal["S", "M", "A", "B", "C", "D"]
SourceScope = Literal["user_messages", "metadata", "stated_profile"]


@dataclass(frozen=True)
class Category:
    id: str
    name: str
    tier: Tier
    source_scope: SourceScope
    description: str
    example: str


