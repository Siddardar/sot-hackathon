TIER_ORDER = ["S", "M", "A", "B", "C", "D"]
VALID_IDS = {c.id for c in CATEGORIES}
CATEGORY_BY_ID = {c.id: c for c in CATEGORIES}


def render_categories_for_prompt(include_tiers: list[str] | None = None) -> str:
    """
    Render the taxonomy for injection into the system prompt.

    Pass include_tiers to build a reduced prompt. For example, when the export
    has no timestamps, drop tier M so the model is not tempted to invent them.
    """
    tiers = include_tiers or TIER_ORDER
    lines: list[str] = []
    for tier in tiers:
        lines.append(f"\nTIER {tier} — {TIER_NAMES[tier]}")
        for cat in (c for c in CATEGORIES if c.tier == tier):
            lines.append(
                f"  - {cat.id} ({cat.name}) [evidence must come from: {cat.source_scope}]: "
                f"{cat.description} Example: {cat.example}"
            )
    return "\n".join(lines)


def leakage_score(findings: list[dict]) -> int:
    """Tier-weighted score. Tier S contributes zero by design."""
    return sum(TIER_WEIGHTS[CATEGORY_BY_ID[f["category_id"]].tier] for f in findings)
