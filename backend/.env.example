# Required: your Anthropic API key (used by the profiler).
ANTHROPIC_API_KEY=sk-ant-...

# Optional overrides (defaults shown).
# PROFILER_MODEL=claude-opus-4-8
# PROFILER_MAX_TOKENS=16000
# PROFILER_EFFORT=medium          # low | medium | high | max
# PROFILER_THINKING=on            # on | off
# PROFILER_MAX_RETRIES=1          # extra generations if a run is fully ungrounded
# STREAM_DELAY_SECONDS=0.15       # per-card stagger delay for /analyze SSE
