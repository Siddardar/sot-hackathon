# Copy this file to backend/.env or export the vars yourself. The profiler loads
# backend/.env automatically. Without any key set, it runs in MOCK mode and
# returns a grounded sample dossier, enough to test the full upload -> parse ->
# analyze pipeline end to end.

# Gemini API key (used by the real profiler). Unset => MOCK mode auto-on.
# GOOGLE_API_KEY=...
# GEMINI_API_KEY=...

# Profiler mode: auto (mock when no Gemini key) | 1/on (force) | 0/off (real)
# PROFILER_MOCK=auto

# Optional overrides (defaults shown).
# PROFILER_MODEL=gemini-3.5-flash
# PROFILER_MAX_TOKENS=16000
# PROFILER_TEMPERATURE=0.3
# PROFILER_MAX_RETRIES=1          # extra generations if a run is fully ungrounded
# STREAM_DELAY_SECONDS=0.15       # per-card stagger delay for /analyze SSE
